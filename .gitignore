# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
*.so

# ── Virtual environment ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Environment / secrets ───────────────────────────────────────────────────
.env
*.env.local
*.env.*.local
secrets.toml
.streamlit/secrets.toml

# ── Large pipeline outputs (local only) ─────────────────────────────────────
# Parquet + JSON intermediaries (too large; regenerated by running the pipeline)
output/docling_json/
output/llm_docs/
output/llm_raw/
output/chunks/
output/*/docling_json/
output/*/llm_docs/
output/*/llm_raw/
output/*/chunks/
# Large log files
output/*.log
output/**/*.log
logs/

# ── PDFs ────────────────────────────────────────────────────────────────────
# Don't commit source PDFs (they live on Windows drives or shared storage)
raw_data/pdfs/
data/pdfs/
output/corpus_flat_pdfs/
*.pdf

# ── Large CSV / data files kept in repo (small indexes are checked in) ───────
# The master issuer list is 10k rows — keep it (source-of-truth metadata)
# Intermediate pipeline CSVs inside output/ — too volatile
output/csv/
output/*/csv/
output/human_review/
output/companies/
output/corpus_configs/*.yaml
# SFT training data (derived artifacts; regenerate with build_sft_dataset.py)
output/sft/*.jsonl
output/sft/*.parquet

# ── Streamlit cache ─────────────────────────────────────────────────────────
.streamlit/
!.streamlit/config.toml

# ── Jupyter ─────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── OS / editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/settings.json

# ── Misc temp files ─────────────────────────────────────────────────────────
*.tmp
*.bak
*.orig
"Yes. On SEDAR+*"
