# Copy to `.env` and adjust. Paths are relative to project root unless absolute.
#
# Install order:
#   pip install --force-reinstall torch torchvision --index-url https://download.pytorch.org/whl/cpu
#   pip install -r requirements.txt

PROJECT_ROOT=

# Docling pulls layout models from Hugging Face. In WSL, set a Linux-writable cache (e.g. under
# $HOME), not a Windows path like /mnt/d/volumes/... that may raise Permission denied.
# HF_HOME=/home/you/.cache/huggingface

# OpenAI-compatible vLLM (AWQ Marlin / quantization is configured on the server side).
# Free GPU for Docling: python3 scripts/vllm_release_gpu.py
# Thomas vLLM: sudo systemctl stop thomas-vllm  →  Docling  →  sudo systemctl start thomas-vllm
# Optional: after Docling the pipeline runs `systemctl start` and waits for /v1/models (needs sudo or polkit).
# PIPELINE_VLLM_SYSTEMD_UNIT=thomas-vllm
# PIPELINE_VLLM_START_TIMEOUT_SEC=600
VLLM_BASE_URL=http://127.0.0.1:8000/v1
# If the server uses ``--api-key`` (Thomas), set this to the same value or GET /v1/models returns 401
# and pipeline health checks will fail. Use EMPTY only when the server has no API key.
VLLM_API_KEY=local-vllm-key
# Must match the model id from GET {VLLM_BASE_URL}/models (served id for Qwen3-14B-AWQ, etc.).
# Use the exact id from GET {VLLM_BASE_URL}/models (e.g. Qwen/Qwen3-14B-AWQ).
VLLM_MODEL_NAME=Qwen/Qwen3-14B-AWQ

VLLM_MAX_TOKENS=2048
# Must match --max-model-len in your vllm serve command. Restart vLLM if you change this.
# Qwen3-14B-AWQ on 4090: use 32768 (fits KV cache in VRAM); 110000 OOMs at full util.
# VLLM_MODEL_MAX_CONTEXT_TOKENS=32768
# Reserve for system prompt, user wrapper, guided JSON schema overhead.
# LLM_CHUNK_PROMPT_RESERVE_TOKENS=8000
# Pass-1 completion cap; Pass-2 uses VLLM_MAX_TOKENS × 1.5.
# LLM_CHUNK_MAX_TOKENS=4096

VLLM_TEMPERATURE=0.0
VLLM_TOP_P=1.0
# In-flight HTTP connections. Raise by 16 until nvidia-smi SM util sits at 85-92%.
VLLM_MAX_CONCURRENT_REQUESTS=48
# Alias:
# VLLM_CONCURRENCY=48
# Pass-1: max rows per asyncio.gather (HTTP still capped by VLLM_MAX_CONCURRENT_REQUESTS).
# LLM_CHUNK_GATHER_BATCH_SIZE=512
# Flush chunks_llm.parquet every N vLLM completions.
# LLM_CHUNK_CHECKPOINT_EVERY=100

VLLM_TIMEOUT_SEC=600
VLLM_MAX_RETRIES=4

# Qwen3 extraction: thinking mode burns batch capacity; keep false for Pass 1/2 JSON.
# Merged into extra_body["chat_template_kwargs"] (with guided_json when USE_GUIDED_DECODING=1).
VLLM_CHAT_TEMPLATE_KWARGS='{"enable_thinking": false}'

# Send JSON schemas as extra_body["guided_json"] (vLLM); may downgrade response_format json_schema → json_object.
USE_GUIDED_DECODING=1

# json_object | json_schema | none — when USE_GUIDED_DECODING=1 and this is json_schema, client uses json_object + guided_json.
VLLM_RESPONSE_FORMAT=json_object

# LangGraph: set for on-disk checkpoint resume across processes (sync SqliteSaver).
# CHECKPOINT_SQLITE_PATH=output/checkpoints.db

# Self-healing: retry until parse + chunks + LLM + issuer-year outputs align with filings_index.
#   python3 scripts/pipeline_supervisor.py --status
#   ./scripts/run_supervised_pipeline.sh -- --max-attempts 0
#   (completion includes review_ready.csv; add --no-require-review to skip that check)
# Optional: before each attempt, wait for vLLM (reduces subprocess churn when LLM is down):
#   PIPELINE_SUPERVISOR_WAIT_VLLM=1
# Override wait cap: pass --vllm-wait-sec to pipeline_supervisor.py

# Per-company filing JSON: output/companies/{ticker}/{filing_id}_filing_llm.json
# COMPANIES_OUTPUT_DIR=output/companies

# I/O (PDFs live under data/pdfs/{company}/...; set FILINGS_PDF_ROOT if local_path in index is relative)
FILINGS_INDEX_PATH=data/metadata/filings_index.csv
TICKERS_PATH=data/metadata/tickers_with_profiles.csv
DOC_JSON_DIR=output/docling_json
CHUNKS_PARQUET=output/chunks/chunks.parquet
PARSE_INDEX_CSV=output/docling_parse_index.csv
CHUNKS_LLM_PARQUET=output/llm_raw/chunks_llm.parquet
FILINGS_LLM_PARQUET=output/llm_docs/filings_llm.parquet
FILINGS_LLM_CSV=output/csv/filings_llm.csv
ISSUER_YEAR_CSV=output/csv/issuer_year_tariff_signals.csv
REVIEW_CSV=output/human_review/review_ready.csv

FILINGS_PDF_ROOT=data/pdfs

CHUNK_TARGET_TOKENS=1200

# Docling GPU: install PyTorch with CUDA for your driver, e.g.
#   pip install --force-reinstall torch torchvision --index-url https://download.pytorch.org/whl/cu124
# Then set auto (default) or cuda / cuda:0. CPU-only torch forces CPU (~40s+/page class workloads).
# DOCLING_DEVICE=auto
# DOCLING_NUM_THREADS=8
# Speed vs quality (born-digital MD&As often tolerate DOCLING_DO_OCR=0 — large win):
# DOCLING_DO_OCR=1
# DOCLING_DO_TABLE_STRUCTURE=1
# DOCLING_TABLE_FORMER_MODE=accurate
# Threaded pipeline batch sizes — try 8–12 on a 4090 if VRAM headroom:
# DOCLING_OCR_BATCH_SIZE=4
# DOCLING_LAYOUT_BATCH_SIZE=4
# DOCLING_TABLE_BATCH_SIZE=4
# DOCLING_SKIP_CELL_ASSIGNMENT=0
# After each PDF: torch.cuda.empty_cache() (may reduce rare GPU segfaults during long runs).
# DOCLING_CUDA_EMPTY_CACHE_EACH_PDF=1
# Rebuild Docling converters every N OK PDFs (0=never). Try 15–25 if the process dies with exit -11.
# DOCLING_CONVERTER_RESET_EVERY=0

SKIP_PARSE_IF_EXISTS=1
SKIP_CHUNK_IF_EXISTS=1
SKIP_LLM_CHUNK_IF_EXISTS=1
SKIP_LLM_DOC_IF_EXISTS=1
SKIP_AGGREGATE_IF_EXISTS=1
